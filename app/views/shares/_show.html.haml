.details
  %H1
    Details For: #{@share.name} (#{@share.currency})
  .details_buttons
    %button{onclick: "clearDetails()"}
      Clear
    %button{onclick: "callYahooHistoricals(#{@share.id});"}
      Load Yahoo Dividends
    %button{onclick: "callYahooSummary(#{@share.id});"}
      Load Fmp Summary
    %button{onclick: "deleteShare(#{@share.id});"}
      Delete Share
    %button{onclick: "alert('id = #{@share.id}');"}
      Show Internal Id
    %span.active_prompt
      Active: 
    %label.switch
      %input{
        type: "checkbox",
        checked: @share.active,
        data: {
          id: @share.id
        },
        onchange: "toggleShareActive(this)"
      }
      %span.slider
    %span.update_notification{ id: "update_notification" }
      Updated!
    =get_links @share
  .details_pills
    - @share.badges.each do |badge|
      .badge_holder
        = create_pill(badge, @share)
  .sector_industry
    %sp.sector_prompt
      Sector:
    = render :partial => 'shared/field', :locals => { obj: @share, data: @share.sector, field_name: 'sector', display_klass: 'non-table-input' }
    %sp.industry_prompt
      Industry:
    = render :partial => 'shared/field', :locals => { obj: @share, data: @share.industry, field_name: 'industry', display_klass: 'non-table-input' }
  .tab_container
    .tab_headings
      = inner_tab("Dividends", "Dividends")
      = inner_tab("Dividends", "Holdings")
      = inner_tab("Dividends", "Sales")
      = inner_tab("Dividends", "Chart")
      = inner_tab("Dividends", "Summary")
      = inner_tab("Dividends", "History")
      = inner_tab("Dividends", "Alerts")
      = inner_tab("Dividends", "Notes")
    = inner_tab_data("Dividends", "Dividends", 'dividends', { share: @share} )
    = inner_tab_data("Dividends", "Holdings", 'holdings', { share: @share} )
    = inner_tab_data("Dividends", "Sales", 'sales', { share: @share} )
    = inner_tab_data("Dividends", "Chart", 'chart', { share: @share} )
    = inner_tab_data("Dividends", "Summary", 'show_summary', { share: @share} )
    = inner_tab_data("Dividends", "History", 'show_history', { share: @share} )
    = inner_tab_data("Dividends", "Alerts", 'alerts', { share: @share})
    = inner_tab_data("Dividends", "Notes", 'show_notes', { share: @share})